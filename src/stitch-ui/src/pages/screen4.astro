<style>
    body {
      background-color: #0D0D0E;
      color: #e3e2e7;
      overflow-x: hidden;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    /* Custom Glassmorphism Player */
    .glass-player {
      background: rgba(18, 19, 23, 0.4);
      backdrop-filter: blur(24px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    /* Glow Projection */
    .glow-projection {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 120%;
      height: 120%;
      background: radial-gradient(circle, rgba(208, 188, 255, 0.15) 0%, rgba(13, 13, 14, 0) 70%);
      filter: blur(60px);
      z-index: -1;
      animation: pulse-glow 8s infinite alternate ease-in-out;
    }

    @keyframes pulse-glow {
      0% { opacity: 0.4; transform: translate(-50%, -50%) scale(1); }
      100% { opacity: 0.7; transform: translate(-50%, -50%) scale(1.1); }
    }

    .playhead-glow {
      box-shadow: 0 0 15px rgba(208, 188, 255, 0.6);
    }

    .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #494454;
      border-radius: 10px;
    }
  </style>
</head>
<body class="flex items-center justify-center min-h-screen p-margin-mobile md:p-margin-desktop font-body-lg">
<!-- Background Ambient Glow -->
<div class="fixed inset-0 pointer-events-none">
<div class="absolute top-[-10%] right-[-10%] w-[50vw] h-[50vw] bg-primary/10 rounded-full blur-[120px]" />
<div class="absolute bottom-[-10%] left-[-10%] w-[40vw] h-[40vw] bg-tertiary/5 rounded-full blur-[100px]" />
</div>
<!-- Centered Audio Player Canvas -->
<main class="relative z-10 w-full max-w-[500px] flex flex-col items-center">
<!-- Top Bar (Brand Anchor Integration) -->
<div class="w-full flex justify-between items-center mb-10 opacity-60">
<span class="font-headline-md text-headline-md font-black text-primary tracking-tighter">Audio Vault</span>
<button class="material-symbols-outlined text-on-surface hover:text-primary transition-colors">share</button>
</div>
<!-- The Player Core -->
<div class="relative w-full aspect-square mb-12">
<!-- Glow Projection behind art -->
<div class="glow-projection" />
<!-- Cover Art Container -->
<div class="w-full h-full rounded-xl overflow-hidden shadow-2xl border border-outline-variant/30 group cursor-pointer relative">
<img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="/assets/dcb0ed2d82a9147f1102e1432dbb3f6e.png" />
<!-- Overlay interaction hint -->
<div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
<span class="material-symbols-outlined text-[64px] text-white/80" style="font-variation-settings: 'FILL' 1;">zoom_in</span>
</div>
</div>
</div>
<!-- Playback Section -->
<div class="w-full space-y-8 flex flex-col items-center">
<!-- Progress Bar -->
<div class="w-full">
<div class="relative w-full h-[3px] bg-surface-container-highest rounded-full cursor-pointer group">
<!-- Buffered / Background -->
<div class="absolute inset-0 bg-outline-variant/20 rounded-full" />
<!-- Active Progress -->
<div class="absolute inset-y-0 left-0 w-[45%] bg-primary rounded-full transition-all duration-300">
<!-- Playhead -->
<div class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full playhead-glow scale-0 group-hover:scale-100 transition-transform" />
</div>
</div>
<div class="flex justify-between mt-3 px-1">
<span class="font-label-caps text-label-caps text-on-surface-variant">1:42</span>
<span class="font-label-caps text-label-caps text-on-surface-variant">3:45</span>
</div>
</div>
<!-- Controls -->
<div class="flex items-center gap-10">
<button class="material-symbols-outlined text-on-surface-variant hover:text-on-surface transition-all active:scale-90" style="font-size: 28px;">skip_previous</button>
<!-- Custom Play Button (Vibrant Accent) -->
<button class="w-20 h-20 bg-primary-container text-on-primary-container rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(160,120,255,0.4)] hover:shadow-[0_0_50px_rgba(160,120,255,0.6)] transition-all hover:scale-105 active:scale-95 group">
<span class="material-symbols-outlined text-[40px] group-active:opacity-80" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
</button>
