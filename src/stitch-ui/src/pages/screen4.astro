<span class="material-symbols-outlined text-[18px]">high_quality</span>
          24-BIT
        </button>
<div class="w-px h-4 bg-outline-variant/30" />
<button class="flex items-center gap-2 font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[18px]">playlist_add</span>
          QUEUE
        </button>
</div>
</div>
</main>
<!-- Interaction Script for Micro-animations -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
      const playBtn = document.querySelector('button.w-20');
      const icon = playBtn.querySelector('.material-symbols-outlined');
      let isPlaying = false;

      playBtn.addEventListener('click', () => {
        isPlaying = !isPlaying;
        icon.innerText = isPlaying ? 'pause' : 'play_arrow';
        
        // Visual feedback for play/pause toggle
        if(isPlaying) {
          playBtn.classList.add('animate-pulse');
        } else {
          playBtn.classList.remove('animate-pulse');
        }
      });

      // Subtle parallax on the cover art container based on mouse move
      const artContainer = document.querySelector('.overflow-hidden.shadow-2xl');
      document.addEventListener('mousemove', (e) => {
        const x = (window.innerWidth / 2 - e.pageX) / 50;
        const y = (window.innerHeight / 2 - e.pageY) / 50;
        artContainer.style.transform = `rotateY(${x}deg) rotateX(${y}deg)`;
      });
    });
  </script>
</body></html>